APP_ENV=production
SECRET_KEY=replace-with-at-least-32-random-characters
# Dedicated durable pepper for v4.4.1 API-key digests; rotating it invalidates issued keys.
API_KEY_PEPPER=replace-with-an-independent-random-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password
ADMIN_DISPLAY_NAME=John Simo
# AUTH_DISABLED=1  # development only; ignored as a recommendation for production

# Database (SQLite is used when omitted)
# DATABASE_URL=postgresql+psycopg://user:password@host:5432/nfl_analytics

# Phase 10 data platform
DATABASE_URL=postgresql+psycopg://nfl:change-me@localhost:5432/nfl_analytics
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
REDIS_URL=redis://localhost:6379/0
ENABLE_SCHEDULER=false

# External data integration
EXTERNAL_DATA_TIMEOUT=60
EXTERNAL_DATA_SEASON=2025
EXTERNAL_DATASETS=pbp,rosters,injuries,depth_charts,snap_counts
ENABLE_EXTERNAL_SYNC=false

# Credentialed external providers (all optional; integrations fail closed)
ENABLE_COMMERCIAL_SYNC=false
COMMERCIAL_DATASETS=weather,odds,live_games,coaches,transactions
EXTERNAL_DATA_WEEK=
OPENWEATHER_API_KEY=
ODDS_API_KEY=
ODDS_API_URL=https://api.the-odds-api.com/v4/sports/americanfootball_nfl/odds
ODDS_REGIONS=us
ODDS_MARKETS=h2h,spreads,totals
SPORTSDATAIO_API_KEY=
SPORTSDATAIO_BASE_URL=https://api.sportsdata.io/v3/nfl
# Override these templates when your SportsDataIO subscription exposes different routes.
SPORTSDATAIO_COACHES_PATH=scores/json/TeamSeasonStats/{season}
SPORTSDATAIO_TRANSACTIONS_PATH=scores/json/Transactions/{season}

# Version 2.1 integration control plane
ENABLED_PROVIDERS=nflverse,nws
WEATHER_PROVIDER=nws
# NWS requires an identifying user agent; no API key is required.
NWS_USER_AGENT=nfl-analytics-hub/2.1 contact@example.com
# SportsDataIO live score endpoint template (adjust for your subscription/feed).
SPORTSDATAIO_SCORES_PATH=scores/json/Scores/{season}
